<?xml version="1.0"?>
<robot name="car_robot" xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <xacro:property name="base_length" value="0.66"/>
    <xacro:property name="base_width" value="0.36"/>
    <xacro:property name="base_height" value="0.20"/>
    <xacro:property name="wheel_radius" value="0.10"/>
    <xacro:property name="wheel_width" value="0.03"/>

    <!-- base-link -->
    <link name="base_footprint">
        <visual>
            <geometry>
               <sphere radius="0.0001"/>
            </geometry>
        </visual>
    </link>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <material name="blue" >
                <color rgba="0.0 0.0 1.0 0.3"/>
            </material>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </visual>
        <collision>
                <geometry>
                    <box size="${base_length} ${base_width} ${base_height}"/>
                </geometry>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </collision>
        <xacro:box_inertia 
            m="1.0" 
            x="${base_length}" y="${base_width}" z="${base_height}" 
            o_xyz="0.0 0.0 0.0" 
            o_rpy="0.0 0.0 0.0"/>
    </link>

    <!-- wheels-macros -->
    <xacro:macro name="wheel_link" params="wheel_name">
        <link name="${wheel_name}">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
                <material name="green" >
                    <color rgba="0.0 1.0 0.0 0.3"/>
                    
                </material>
                <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
            </visual>
            <collision>
                <geometry>
                   <sphere radius="${wheel_radius}"/>
                </geometry>
                <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
            </collision>
            <xacro:cylinder_inertia 
                m="2.0" 
                r="${wheel_radius}" l="${wheel_width}" 
                o_xyz="0.0 0.0 0.0" 
                o_rpy="1.5708 0.0 0.0"/>
        </link>
    </xacro:macro>

    <!-- wheel-links -->
    <xacro:wheel_link wheel_name="wheel_rear_left"/>
    <xacro:wheel_link wheel_name="wheel_rear_right"/>

    <!-- caster_wheel_link -->
    <link name="caster_wheel">
        <visual>
            <geometry>
                <sphere radius="${wheel_radius}"/>
            </geometry>
            <material name="green" />
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${wheel_radius}"/>
            </geometry>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </collision>
        <xacro:sphere_inertia 
            m="0.5" 
            r="${wheel_radius}" 
            o_xyz="0.0 0.0 0.0" 
            o_rpy="1.5708 0.0 0.0"/>
    </link>

    <!-- base_2_footprint_joint -->
    <joint name="base_2_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0.0 0.0 ${wheel_radius + (base_height)/2}" rpy="0.0 0.0 0.0"/>
    </joint>

    <!-- rear_left_wheel_joint -->
    <joint name="left_rear_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_rear_left"/>
        <origin xyz="${-(base_length/4)} ${(base_width - wheel_width)/2} -${base_height/2}" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <!-- rear_right_wheel_joint -->
    <joint name="right_rear_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_rear_right"/>
        <origin xyz="${-(base_length/4)} ${-(base_width - wheel_width)/2} -${base_height/2}" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <!-- caster_wheel_joint -->
    <joint name="caster_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel"/>
        <origin xyz="${(base_length/4)} 0.0 -${base_height/2}" rpy="0.0 0.0 0.0"/>
    </joint>
</robot>